{
    "name": "rmscms/accounting",
    "description": "Complete Accounting & Financial Management System for Laravel with RMS Core - Double Entry, Multi-Currency, VAT, COGS",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "accounting", "financial", "ledger", "double-entry", "multi-currency", "vat", "rms", "erp", "cogs", "receivables", "payables"],
    "authors": [
        {
            "name": "Sharif Ahrari",
            "email": "msharif.ahrari@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "laravel/sanctum": "^4.2",
        "rmscms/core": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "RMS\\Accounting\\": "src/",
            "RMS\\Accounting\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RMS\\Accounting\\AccountingServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
